.gradle
.idea
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# OS / IDE / tooling artifacts
.DS_Store
*.iml
.kotlin/
hs_err_pid*.log

# Claude Code agent worktrees (never commit material)
.claude/worktrees/
